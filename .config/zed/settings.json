{
  "git_panel": {
    "button": true
  },
  "sticky_scroll": {
    "enabled": false
  },
  "hover_popover_sticky": true,
  "project_panel": {
    "sticky_scroll": false,
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false
  },
  "diff_view_style": "unified",
  "autosave": "on_window_change",
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "model": "claude-sonnet-4.6"
      },
      "favorite_config_option_values": {
        "model": [
          "claude-sonnet-4.6"
        ]
      },
      "type": "registry"
    }
  },
  "icon_theme": "Zed (Default)",
  "colorize_brackets": true,
  "buffer_line_height": {
    "custom": 2.0,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "buffer_font_family": "Victor Mono",
  "buffer_font_size": 14.0,
  "buffer_font_weight": 550.0,
  "cursor_blink": false,
  "relative_line_numbers": "disabled",
  "ui_font_size": 15.0,
  "vim_mode": true,
  "theme": "VSCode Light+",
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "status_bar": {
    "active_language_button": false,
  },
  "terminal": {
    "copy_on_select": true,
    "font_size": 13,
    "font_weight": 500.0,
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo", "vtsls"],
    },
    "Python": {
      "language_servers": ["ty", "basedpyright"],
    },
  },
}
