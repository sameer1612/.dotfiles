# !/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

sketchybar --bar position=top color=15ffffff

default=(
  padding_left=0
  padding_right=0
  icon.font="JetBrainsMono Nerd Font:Regular:14.0"
  label.font="JetBrainsMono Nerd Font:Regular:14.0"
  icon.color=0xaaffffff
  label.color=0xaaffffff
  label.padding_left=6
  label.padding_right=6
  background.padding_right=4
  background.padding_left=4
)
sketchybar --default "${default[@]}"

sketchybar --add item battery right \
  --set battery background.color=0x12ffffff \
  --set battery update_freq=60 script="$PLUGIN_DIR/battery.sh"

sketchybar --add item clock right \
  --set clock background.color=0x12ffffff \
  --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh"

sketchybar --add item meeting right \
  --set meeting background.color=0x12ffffff \
  --set meeting update_freq=60 script="$PLUGIN_DIR/meeting.py"


##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
